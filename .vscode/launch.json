{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: GitHub",
      "type": "node-terminal",
      "request": "launch",
      "command": "${workspaceFolder}/scripts/backend.sh github"
    },
    {
      "name": "Backend: REST Countries",
      "type": "node-terminal",
      "request": "launch",
      "command": "${workspaceFolder}/scripts/backend.sh restcountries"
    },
    {
      "name": "Flutter: App",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app"
    }
  ]
}
